# ─────────────────────────────────────────
# Supabase  (https://supabase.com)
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────
# Stripe  (https://dashboard.stripe.com)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect — routes funds directly to the church's Stripe account.
# Leave blank to process payments into your own account (useful for testing).
CHURCH_STRIPE_ACCOUNT_ID=acct_...

# ─────────────────────────────────────────
# Admin dashboard
# ─────────────────────────────────────────
ADMIN_PASSWORD=choose-a-strong-password

# ─────────────────────────────────────────
# App URL  (update after deploying to Vercel)
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
